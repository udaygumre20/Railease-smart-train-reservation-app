# ============================================================
# RailEase Server – Environment Variables
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL / Neon)
DATABASE_URL="postgresql://user:password@host:5432/railease?schema=public"

# JWT Secrets (generate strong random strings for production)
JWT_ACCESS_SECRET="your-access-token-secret-here"
JWT_REFRESH_SECRET="your-refresh-token-secret-here"

# Token Expiry
ACCESS_TOKEN_EXPIRE="15m"
REFRESH_TOKEN_EXPIRE="7d"

# CORS
CLIENT_URL="http://localhost:3000"
