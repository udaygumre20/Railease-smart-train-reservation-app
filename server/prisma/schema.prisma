generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  phone         String?        @unique
  dateOfBirth   DateTime?      @map("date_of_birth")
  gender        Gender?
  role          Role           @default(USER)
  avatar        String?
  isVerified    Boolean        @default(false) @map("is_verified")
  isActive      Boolean        @default(true) @map("is_active")
  refreshToken  String?        @map("refresh_token")
  lastLoginAt   DateTime?      @map("last_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  bookings      Booking[]
  notifications Notification[]
  seatLocks     SeatLock[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Station {
  id                String      @id @default(uuid())
  code              String      @unique
  name              String
  city              String
  state             String
  zone              String?
  latitude          Decimal?    @db.Decimal(10, 7)
  longitude         Decimal?    @db.Decimal(10, 7)
  platforms         Int         @default(1)
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  arrivalBookings   Booking[]   @relation("AlightingStation")
  departureBookings Booking[]   @relation("BoardingStation")
  routeStops        RouteStop[]

  @@index([code])
  @@index([name])
  @@index([city])
  @@map("stations")
}

model Route {
  id            String       @id @default(uuid())
  name          String
  code          String       @unique
  totalDistance Decimal      @map("total_distance") @db.Decimal(10, 2)
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  stops         RouteStop[]
  trainRoutes   TrainRoute[]

  @@map("routes")
}

model RouteStop {
  id                 String   @id @default(uuid())
  routeId            String   @map("route_id")
  stationId          String   @map("station_id")
  sequenceNumber     Int      @map("sequence_number")
  distanceFromOrigin Decimal  @map("distance_from_origin") @db.Decimal(10, 2)
  arrivalTime        String?  @map("arrival_time")
  departureTime      String?  @map("departure_time")
  haltDuration       Int?     @map("halt_duration")
  dayOffset          Int      @default(0) @map("day_offset")
  platform           Int?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  route              Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  station            Station  @relation(fields: [stationId], references: [id])

  @@unique([routeId, sequenceNumber])
  @@unique([routeId, stationId])
  @@index([routeId])
  @@index([stationId])
  @@map("route_stops")
}

model Train {
  id           String        @id @default(uuid())
  trainNumber  String        @unique @map("train_number")
  name         String
  status       TrainStatus   @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  bookings     Booking[]
  coaches      Coach[]
  racEntries   RAC[]
  seatLocks    SeatLock[]
  trainRoutes  TrainRoute[]
  waitingLists WaitingList[]

  @@index([trainNumber])
  @@index([name])
  @@index([status])
  @@map("trains")
}

model TrainRoute {
  id            String      @id @default(uuid())
  trainId       String      @map("train_id")
  routeId       String      @map("route_id")
  runDays       DayOfWeek[] @map("run_days")
  effectiveFrom DateTime    @map("effective_from")
  effectiveTo   DateTime?   @map("effective_to")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  route         Route       @relation(fields: [routeId], references: [id])
  train         Train       @relation(fields: [trainId], references: [id], onDelete: Cascade)

  @@unique([trainId, routeId])
  @@index([trainId])
  @@index([routeId])
  @@index([isActive])
  @@map("train_routes")
}

model CoachType {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  seatLayout    Json?    @map("seat_layout")
  seatsPerCoach Int      @map("seats_per_coach")
  hasAC         Boolean  @default(false) @map("has_ac")
  berthTiers    Int      @map("berth_tiers")
  baseFarePerKm Decimal  @map("base_fare_per_km") @db.Decimal(6, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  coaches       Coach[]

  @@map("coach_types")
}

model Coach {
  id          String    @id @default(uuid())
  coachNumber String    @map("coach_number")
  trainId     String    @map("train_id")
  coachTypeId String    @map("coach_type_id")
  sequence    Int
  totalSeats  Int       @map("total_seats")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  coachType   CoachType @relation(fields: [coachTypeId], references: [id])
  train       Train     @relation(fields: [trainId], references: [id], onDelete: Cascade)
  seats       Seat[]

  @@unique([trainId, coachNumber])
  @@index([trainId])
  @@index([coachTypeId])
  @@map("coaches")
}

model Seat {
  id          String     @id @default(uuid())
  seatNumber  Int        @map("seat_number")
  seatType    SeatType   @map("seat_type")
  coachId     String     @map("coach_id")
  isAvailable Boolean    @default(true) @map("is_available")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  racEntries  RAC[]
  seatLocks   SeatLock[]
  coach       Coach      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  tickets     Ticket[]

  @@unique([coachId, seatNumber])
  @@index([coachId])
  @@index([isAvailable])
  @@index([seatType])
  @@map("seats")
}

model Booking {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  trainId            String        @map("train_id")
  boardingStationId  String        @map("boarding_station_id")
  alightingStationId String        @map("alighting_station_id")
  journeyDate        DateTime      @map("journey_date")
  totalPassengers    Int           @map("total_passengers")
  totalFare          Decimal       @map("total_fare") @db.Decimal(10, 2)
  status             BookingStatus @default(PENDING)
  quota              Quota         @default(GENERAL)
  coachPreference    String?       @map("coach_preference")
  bookingDate        DateTime      @default(now()) @map("booking_date")
  cancelledAt        DateTime?     @map("cancelled_at")
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  alightingStation   Station       @relation("AlightingStation", fields: [alightingStationId], references: [id])
  boardingStation    Station       @relation("BoardingStation", fields: [boardingStationId], references: [id])
  train              Train         @relation(fields: [trainId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  passengers         Passenger[]
  payment            Payment?
  pnr                PNR?

  @@index([userId])
  @@index([trainId])
  @@index([journeyDate])
  @@index([status])
  @@index([bookingDate])
  @@index([trainId, journeyDate])
  @@map("bookings")
}

model Passenger {
  id              String       @id @default(uuid())
  bookingId       String       @map("booking_id")
  firstName       String       @map("first_name")
  lastName        String       @map("last_name")
  age             Int
  gender          Gender
  nationality     String       @default("IN")
  idType          String?      @map("id_type")
  idNumber        String?      @map("id_number")
  seatPreference  SeatType?    @map("seat_preference")
  isLeadPassenger Boolean      @default(false) @map("is_lead_passenger")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  booking         Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rac             RAC?
  ticket          Ticket?
  waitingList     WaitingList?

  @@index([bookingId])
  @@map("passengers")
}

model Ticket {
  id          String       @id @default(uuid())
  passengerId String       @unique @map("passenger_id")
  seatId      String       @map("seat_id")
  status      TicketStatus @default(CONFIRMED)
  coachNumber String       @map("coach_number")
  seatNumber  Int          @map("seat_number")
  seatType    SeatType     @map("seat_type")
  fare        Decimal      @db.Decimal(10, 2)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  passenger   Passenger    @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  seat        Seat         @relation(fields: [seatId], references: [id])

  @@index([passengerId])
  @@index([seatId])
  @@index([status])
  @@map("tickets")
}

model Payment {
  id              String         @id @default(uuid())
  bookingId       String         @unique @map("booking_id")
  amount          Decimal        @db.Decimal(10, 2)
  currency        String         @default("INR")
  method          PaymentMethod?
  status          PaymentStatus  @default(PENDING)
  transactionId   String?        @unique @map("transaction_id")
  gatewayOrderId  String?        @unique @map("gateway_order_id")
  gatewayResponse Json?          @map("gateway_response")
  refundAmount    Decimal?       @map("refund_amount") @db.Decimal(10, 2)
  refundId        String?        @map("refund_id")
  paidAt          DateTime?      @map("paid_at")
  refundedAt      DateTime?      @map("refunded_at")
  failureReason   String?        @map("failure_reason")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  booking         Booking        @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([transactionId])
  @@index([status])
  @@index([paidAt])
  @@map("payments")
}

model PNR {
  id            String        @id @default(uuid())
  bookingId     String        @unique @map("booking_id")
  pnrNumber     String        @unique @map("pnr_number")
  status        BookingStatus
  chartPrepared Boolean       @default(false) @map("chart_prepared")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  booking       Booking       @relation(fields: [bookingId], references: [id])

  @@index([pnrNumber])
  @@index([bookingId])
  @@map("pnr_records")
}

model WaitingList {
  id             String         @id @default(uuid())
  passengerId    String         @unique @map("passenger_id")
  trainId        String         @map("train_id")
  journeyDate    DateTime       @map("journey_date")
  coachTypeCode  String         @map("coach_type_code")
  waitlistNumber Int            @map("waitlist_number")
  status         WaitlistStatus @default(WAITING)
  promotedAt     DateTime?      @map("promoted_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  passenger      Passenger      @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  train          Train          @relation(fields: [trainId], references: [id])

  @@unique([trainId, journeyDate, coachTypeCode, waitlistNumber])
  @@index([trainId, journeyDate])
  @@index([coachTypeCode])
  @@index([status])
  @@map("waiting_list")
}

model RAC {
  id          String    @id @default(uuid())
  passengerId String    @unique @map("passenger_id")
  seatId      String    @map("seat_id")
  trainId     String    @map("train_id")
  journeyDate DateTime  @map("journey_date")
  racNumber   Int       @map("rac_number")
  status      RACStatus @default(RAC)
  promotedAt  DateTime? @map("promoted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  passenger   Passenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  seat        Seat      @relation(fields: [seatId], references: [id])
  train       Train     @relation(fields: [trainId], references: [id])

  @@unique([trainId, journeyDate, racNumber])
  @@index([trainId, journeyDate])
  @@index([seatId])
  @@index([status])
  @@map("rac_entries")
}

model SeatLock {
  id          String   @id @default(uuid())
  seatId      String   @map("seat_id")
  userId      String   @map("user_id")
  trainId     String   @map("train_id")
  journeyDate DateTime @map("journey_date")
  lockedAt    DateTime @default(now()) @map("locked_at")
  expiresAt   DateTime @map("expires_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  seat        Seat     @relation(fields: [seatId], references: [id])
  train       Train    @relation(fields: [trainId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([seatId, trainId, journeyDate], map: "unique_seat_lock_per_journey")
  @@index([seatId])
  @@index([userId])
  @@index([trainId, journeyDate])
  @@index([expiresAt])
  @@index([isActive])
  @@map("seat_locks")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

enum Role {
  USER
  ADMIN
  AGENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TrainStatus {
  ACTIVE
  CANCELLED
  SUSPENDED
}

enum SeatType {
  LOWER
  MIDDLE
  UPPER
  SIDE_LOWER
  SIDE_UPPER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  RAC
  CANCELLED
  EXPIRED
}

enum TicketStatus {
  CONFIRMED
  WAITLISTED
  RAC
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  UPI
  NET_BANKING
  WALLET
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
}

enum RACStatus {
  RAC
  PROMOTED
  CANCELLED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  WAITLIST_PROMOTED
  RAC_PROMOTED
  TRAIN_DELAY
  DEPARTURE_REMINDER
  GENERAL
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Quota {
  GENERAL
  LADIES
  TATKAL
  PREMIUM_TATKAL
  SENIOR_CITIZEN
  DIVYAANG
  DEFENCE
  FOREIGN_TOURIST
}
